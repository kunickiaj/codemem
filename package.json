{
  "name": "@kunickiaj/codemem",
  "version": "0.19.0",
  "description": "CodeMem plugin for OpenCode",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "README.md",
    "LICENSE",
    ".opencode/plugin/codemem.js",
    ".opencode/lib/compat.js"
  ],
  "scripts": {
    "clean": "pnpm -r run clean && pnpm exec tsc --build --clean",
    "build": "pnpm -r run build && pnpm exec tsc --build",
    "test": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest",
    "lint": "pnpm exec biome check packages/",
    "format": "pnpm exec biome check --write packages/",
    "typecheck": "pnpm exec tsc --build",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "typescript": "^5.8.2",
    "vite": "^8.0.0",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kunickiaj/codemem.git"
  },
  "homepage": "https://github.com/kunickiaj/codemem",
  "bugs": {
    "url": "https://github.com/kunickiaj/codemem/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "codemem"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3"
    ]
  }
}
