{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"paths": {
			"react": ["./node_modules/preact/compat/"],
			"react-dom": ["./node_modules/preact/compat/"],
			"react-dom/*": ["./node_modules/preact/compat/*"],
			"react/jsx-runtime": ["./node_modules/preact/jsx-runtime"]
		},
		"strict": false,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src"]
}
